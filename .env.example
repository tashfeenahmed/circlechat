PG_PASSWORD=circlechat
SESSION_SECRET=change-me-at-least-32-chars-long-string
PUBLIC_BASE_URL=http://localhost:8080
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_PUBLIC_BASE=http://localhost:9000/circlechat
# Leave SMTP_URL empty in dev — invite URLs print to logs instead.
SMTP_URL=
VITE_API_URL=/api
VITE_WS_URL=/events

# ── Agent intelligence (optional) — full reference in docs/CONFIG.md ──
# Server-side planning + the verification judge need an OpenAI-compatible
# /chat/completions endpoint. Without one they stay dormant (no errors).
# PLANNER_BASE_URL=
# PLANNER_API_KEY=
# PLANNER_MODEL=auto
# EMBEDDINGS_BASE_URL=        # also used as the planner fallback + for RAG
# EMBEDDINGS_API_KEY=

# Behaviour gates — OFF/conservative by default. Enable only with a capable model.
# VERIFY_GATE=on              # LLM-judge gate before review→done (fails open; textual deliverables only)
# VERIFIER_PASS_THRESHOLD=0.6
# VERIFY_EXEC=on              # also RENDER web (.html) deliverables in headless Chromium and feed what loaded to the judge (needs VERIFY_GATE=on + chromium; fails open)
# VERIFY_EXEC_TIMEOUT_MS=8000 # hard cap per render
# CHROMIUM_BIN=/usr/bin/chromium
# GOAL_STALL_REPLAN=on        # auto re-plan stalled goals (archives+regenerates open tasks); default just notifies the owner
# ENFORCE_AGENT_SCOPES=off    # default ON; set off for a trusted single-tenant deploy
# APPROVE_RISK_AT=medium      # force approval for actions at/above this risk (low|medium|high)
